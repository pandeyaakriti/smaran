# ── App ──────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-me-in-production

# ── Backend ──────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── Frontend ─────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000

# ── Database ─────────────────────────────────────────
SQLITE_DB_PATH=./data/smaran.db
CHROMA_DB_PATH=./data/chroma_db
CHROMA_COLLECTION_FACES=faces
CHROMA_COLLECTION_MEMORY=memory

# ── Face Recognition ─────────────────────────────────
FACE_SIMILARITY_THRESHOLD=0.6
FACE_DETECTION_MODEL=buffalo_l
FACE_FRAME_SKIP=3              # Process every Nth frame

# ── Speech / Whisper ─────────────────────────────────
WHISPER_MODEL_SIZE=base        # tiny | base | small | medium | large-v3
WHISPER_DEVICE=cpu             # cpu | cuda
WHISPER_LANGUAGE=en

# ── LLM / Ollama ─────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2          # or mistral, gemma2, etc.
OLLAMA_CONTEXT_WINDOW=4096

# ── WebSocket ────────────────────────────────────────
WS_MAX_CONNECTIONS=10
WS_HEARTBEAT_INTERVAL=30
